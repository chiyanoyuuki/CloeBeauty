+
+      <!-- ============== GALERIE / PORTFOLIO ============== -->
+      <div *ngIf="activeTab === 'gallery'">
+        <p class="ccb-hint">
+          Photos du portfolio. Cliquez sur "Changer" pour téléverser une nouvelle image.
+        </p>
+
+        <h3>Portfolio principal ({{ data.portfolio.length }})</h3>
+        <div class="ccb-grid">

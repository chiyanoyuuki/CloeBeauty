+}
+
+.ccb-mini {
+  border: 1px solid $line;
+  background: #fff;
+  color: #6a5a74;
+  border-radius: 6px;
+  padding: 3px 8px;
+  cursor: pointer;
+  font-size: 12px;
+
+  &.del {

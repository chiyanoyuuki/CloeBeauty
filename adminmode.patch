+    margin-right: 4px;
+  }
+}
+
+.ccb-spacer {
+  flex: 1 1 auto;
+}
+
+.ccb-card-actions {
+  display: flex;
+  gap: 6px;
+  flex-wrap: wrap;
+  margin-top: 6px;
+}
+
+// ---------- Images ----------
+.ccb-imgfield {
+  display: flex;
+  gap: 10px;
+  margin-bottom: 10px;
+  align-items: flex-start;
+}
+
+.ccb-preview {

+// ===========================================================
+//  Mode admin — styles isolés (priment sur les styles du site)
+// ===========================================================
+$accent: #aa82ba;
+$accent-dark: #87528e;
+$bg: #ffffff;
+$line: #e7e1ec;
+
+.ccb-admin,
+.ccb-admin * {
+  font-family:
+    -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial,
+    sans-serif !important;
+  box-sizing: border-box;
+}
+
+.ccb-admin {
+  position: fixed;
+  inset: 0;
+  z-index: 999999;
+  pointer-events: none; // laisse passer les clics là où il n'y a pas de panneau
+
+  button,
+  input,
+  textarea,
+  select,
+  label {
+    pointer-events: auto;
+  }
+
+  input,
+  textarea,
+  select {
+    -webkit-appearance: auto;
+    appearance: auto;
+    -webkit-user-select: text;
+    user-select: text;
+  }
+}
+
+// ---------- Connexion ----------
+.ccb-login {
+  position: absolute;
+  inset: 0;
+  background: rgba(40, 30, 50, 0.55);
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  pointer-events: auto;
+}
+
+.ccb-login-box {
+  background: $bg;
+  padding: 28px;
+  border-radius: 14px;
+  width: min(360px, 90vw);
+  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
+  text-align: center;
+
+  h2 {
+    margin: 0 0 6px;
+    color: $accent-dark;
+    font-size: 20px;
+  }
+  p {
+    margin: 0 0 16px;
+    color: #666;
+    font-size: 13px;
+  }
+  input {
+    width: 100%;
+    padding: 11px 12px;
+    border: 1px solid $line;
+    border-radius: 9px;
+    font-size: 15px;
+    margin-bottom: 10px;
+  }
+}
+
+.ccb-login-actions {
+  display: flex;
+  gap: 8px;
+  justify-content: center;
+}
+
+.ccb-error {
+  color: #c0392b !important;
+  font-size: 13px;
+  margin: 0 0 10px !important;
+}
+
+// ---------- Panneau ----------
+.ccb-panel {
+  position: absolute;
+  top: 0;
+  right: 0;
+  height: 100%;
+  width: min(460px, 100vw);
+  background: #faf8fc;
+  box-shadow: -8px 0 40px rgba(0, 0, 0, 0.18);
+  display: flex;
+  flex-direction: column;
+  pointer-events: auto;
+}
+
+.ccb-header {
+  background: $bg;
+  border-bottom: 1px solid $line;
+  padding: 12px 14px 0;
+  flex: 0 0 auto;
+}
+
+.ccb-header-top {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+}
+
+.ccb-title {
+  font-weight: 700;
+  color: $accent-dark;
+  font-size: 15px;
+}
+
+.ccb-lang button {
+  border: 1px solid $line;
+  background: #fff;
+  padding: 4px 10px;
+  cursor: pointer;
+  font-size: 12px;
+  &:first-child {
+    border-radius: 7px 0 0 7px;
+  }
+  &:last-child {
+    border-radius: 0 7px 7px 0;
+    border-left: none;
+  }
+  &.active {
+    background: $accent;
+    color: #fff;
+    border-color: $accent;
+  }
+}
+
+.ccb-header-actions {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  margin: 10px 0;
+  flex-wrap: wrap;
+}
+
+.ccb-save-status {
+  font-size: 12px;
+  font-weight: 600;
+  &.ok {
+    color: #2e7d32;
+  }
+  &.error {
+    color: #c0392b;
+  }
+}
+
+.ccb-tabs {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 4px;
+  padding-bottom: 8px;
+
+  button {
+    border: none;
+    background: #f0eaf4;
+    color: #6a5a74;
+    padding: 6px 10px;
+    border-radius: 7px;
+    cursor: pointer;
+    font-size: 12px;
+    &.active {
+      background: $accent;
+      color: #fff;
+    }
+  }
+}
+
+// ---------- Corps ----------
+.ccb-body {
+  flex: 1 1 auto;
+  overflow-y: auto;
+  padding: 14px;
+
+  h3 {
+    margin: 18px 0 8px;
+    font-size: 14px;
+    color: $accent-dark;
+    border-bottom: 1px solid $line;
+    padding-bottom: 4px;
+  }
+}
+
+.ccb-hint {
+  font-size: 12px;
+  color: #80708a;
+  background: #f3edf7;
+  padding: 8px 10px;
+  border-radius: 8px;
+  margin: 0 0 12px;
+}
+
+.ccb-card {
+  background: #fff;
+  border: 1px solid $line;
+  border-radius: 10px;
+  padding: 12px;
+  margin-bottom: 12px;
+
+  &.group {
+    background: #fbf6ff;
+  }
+}
+
+.ccb-subcard {
+  background: #f7f2fb;
+  border: 1px solid $line;
+  border-radius: 8px;
+  padding: 10px;
+  margin: 8px 0;
+}
+
+.ccb-row {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  margin-bottom: 8px;
+
+  &.col {
+    flex-direction: column;
+    align-items: stretch;
+    gap: 3px;
+  }
+  &.inline {
+    flex-wrap: wrap;
+  }
+
+  label {
+    font-size: 12px;
+    color: #6a5a74;
+    min-width: 84px;
+    font-weight: 600;
+  }
+
+  input[type='text'],
+  input[type='password'],
+  textarea,
+  select {
+    flex: 1 1 auto;
+    width: 100%;
+    padding: 8px 9px;
+    border: 1px solid $line;
+    border-radius: 7px;
+    font-size: 13px;
+    background: #fff;
+    color: #2a2230;
+  }
+  textarea {
+    resize: vertical;
+    line-height: 1.4;
+  }

+            <div class="ccb-thumb-actions">
+              <label class="ccb-upload">
+                Changer
+                <input type="file" accept="image/*" hidden
+                  (change)="uploadInto(data.portfolio, i, 'portfolio', $event, 'pf' + i)" />
+              </label>
+              <button class="ccb-mini" (click)="moveUp(data.portfolio, i)">↑</button>

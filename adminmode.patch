+  background: #fff;
+
+  img {
+    width: 100%;
+    height: 90px;
+    object-fit: cover;
+    display: block;
+  }
+}
+
+.ccb-thumb-actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 3px;
+  padding: 4px;
+  justify-content: center;
+}
+
+.ccb-up {
+  position: absolute;
+  top: 4px;
+  right: 6px;
+  background: rgba(170, 130, 186, 0.9);
+  color: #fff;
+  border-radius: 6px;
+  padding: 0 5px;
+  font-size: 12px;
+}
+
+// ---------- Boutons ----------
+.ccb-upload {
+  display: inline-block;
+  background: $accent;
+  color: #fff !important;
+  padding: 6px 10px;
+  border-radius: 7px;
+  cursor: pointer;
+  font-size: 12px;
+  text-align: center;
+}
+
+.ccb-btn {
+  border: none;
+  background: $accent;
+  color: #fff;
+  padding: 9px 14px;
+  border-radius: 8px;
+  cursor: pointer;
+  font-size: 13px;
+  font-weight: 600;
+
+  &.save {

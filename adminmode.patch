+<!-- =========================================================
+     MODE ADMIN — overlay (n'affiche rien pour les visiteurs)
+     ========================================================= -->
+<div class="ccb-admin" *ngIf="open">
+  <!-- ---------- Écran de connexion ---------- -->
+  <div class="ccb-login" *ngIf="!authed">
+    <div class="ccb-login-box">
+      <h2>Mode administration</h2>
+      <p>Entrez le mot de passe pour modifier le site.</p>
+      <input
+        type="password"
+        [(ngModel)]="passwordInput"
+        (keyup.enter)="login()"
+        placeholder="Mot de passe"
+        autofocus
+      />
+      <p class="ccb-error" *ngIf="loginError">{{ loginError }}</p>
+      <div class="ccb-login-actions">
+        <button class="ccb-btn ghost" (click)="close()">Annuler</button>
+        <button class="ccb-btn" [disabled]="loggingIn" (click)="login()">
+          {{ loggingIn ? 'Connexion…' : 'Entrer' }}
+        </button>
+      </div>
+    </div>
+  </div>
+
+  <!-- ---------- Panneau d'édition ---------- -->
+  <div class="ccb-panel" *ngIf="authed && data">
+    <!-- En-tête -->
+    <div class="ccb-header">
+      <div class="ccb-header-top">
+        <span class="ccb-title">✦ Édition du site</span>
+        <div class="ccb-lang">
+          <button [class.active]="lang === 'fr'" (click)="lang = 'fr'">FR</button>
+          <button [class.active]="lang === 'en'" (click)="lang = 'en'">EN</button>
+        </div>
+      </div>
+      <div class="ccb-header-actions">
+        <button class="ccb-btn save" [disabled]="saving" (click)="save()">
+          {{ saving ? 'Enregistrement…' : '💾 Enregistrer' }}
+        </button>
+        <span class="ccb-save-status ok" *ngIf="saveStatus === 'ok'">✔ Enregistré</span>
+        <span class="ccb-save-status error" *ngIf="saveStatus === 'error'">✖ Erreur</span>
+        <button class="ccb-btn ghost" (click)="close()">Réduire</button>
+        <button class="ccb-btn ghost" (click)="logout()">Quitter</button>
+      </div>
+      <!-- Onglets -->
+      <div class="ccb-tabs">
+        <button
+          *ngFor="let tab of tabs"
+          [class.active]="activeTab === tab.id"
+          (click)="activeTab = tab.id"
+        >
+          {{ tab.label }}
+        </button>
+      </div>
+    </div>
+
+    <!-- Corps -->
+    <div class="ccb-body">
+      <!-- ============== MENU ============== -->
+      <div *ngIf="activeTab === 'menu'">
+        <p class="ccb-hint">Libellés du menu, visibilité et ordre des pages.</p>
+        <div class="ccb-card" *ngFor="let m of data.topmenu; let i = index">
+          <div class="ccb-row">
+            <label>FR</label><input type="text" [(ngModel)]="m.fr" />
+          </div>
+          <div class="ccb-row">
+            <label>EN</label><input type="text" [(ngModel)]="m.en" />
+          </div>
+          <div class="ccb-row inline">
+            <label><input type="checkbox" [(ngModel)]="m.active" /> Active</label>
+            <label><input type="checkbox" [(ngModel)]="m.hidden" /> Masquée</label>
+            <span class="ccb-spacer"></span>
+            <button class="ccb-mini" (click)="moveUp(data.topmenu, i)">↑</button>
+            <button class="ccb-mini" (click)="moveDown(data.topmenu, i)">↓</button>
+          </div>
+        </div>
+      </div>
+
+      <!-- ============== ACCUEIL ============== -->
+      <div *ngIf="activeTab === 'home'">
+        <p class="ccb-hint">Phrase d’accroche, textes et cartes de la page d’accueil.</p>
+
+        <h3>Phrase d’accroche</h3>
+        <textarea rows="2" [(ngModel)]="data.trads[lang]['hero']"></textarea>
+
+        <h3>Paragraphes d’introduction</h3>
+        <ng-container
+          *ngTemplateOutlet="area; context: { obj: data.trads[lang], key: 'accueil_0_0', label: 'Paragraphe 1' }"
+        ></ng-container>
+        <ng-container
+          *ngTemplateOutlet="area; context: { obj: data.trads[lang], key: 'accueil_0_1', label: 'Paragraphe 2' }"
+        ></ng-container>
+        <ng-container
+          *ngTemplateOutlet="area; context: { obj: data.trads[lang], key: 'accueil_0_2', label: 'Paragraphe 3' }"
+        ></ng-container>
+        <ng-container
+          *ngTemplateOutlet="area; context: { obj: data.trads[lang], key: 'accueil_0_3', label: 'Paragraphe 4' }"
+        ></ng-container>
+
+        <h3>Cartes "Découvrez"</h3>
+        <div class="ccb-card" *ngFor="let g of data.galleries; let i = index">
